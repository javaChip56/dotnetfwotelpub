  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.package.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
